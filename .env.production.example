# Accounting backend production environment for hiddenoasis.app.
# Copy to /etc/hiddenoasis/accounting-backend.env on the server.
# Generate real secrets on the server; do not reuse the sample values below.

APP_NAME="Resort Accounting ERP"
ENVIRONMENT=production
API_PREFIX=/api
PORT=8100

DATABASE_URL=postgresql+psycopg://hiddenoasis_erp_app:CHANGE_ME_ERP_DB_PASSWORD@127.0.0.1:5432/hiddenoasis_erp_live
POSTGRES_DB=hiddenoasis_erp_live
POSTGRES_USER=hiddenoasis_erp_app
POSTGRES_PASSWORD=CHANGE_ME_ERP_DB_PASSWORD

SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOW_DEFAULT_ADMIN_BOOTSTRAP=false
ALLOW_DEMO_SEED=false
STARTUP_REQUIRE_MIGRATIONS=true

INTEGRATION_ENABLED=true
INTEGRATION_USERNAME=pos_integration
INTEGRATION_PASSWORD=CHANGE_ME_STRONG_INTEGRATION_USER_PASSWORD
INTEGRATION_SECRET=CHANGE_ME_SHARED_POS_ACCOUNTING_INTEGRATION_SECRET
INTEGRATION_API_KEY=CHANGE_ME_SHARED_CROSS_APP_INTEGRATION_API_KEY

CORS_ORIGINS=https://hiddenoasis.app,https://pos.hiddenoasis.app
UPLOADS_DIR=/var/lib/hiddenoasis/accounting/uploads
PUBLIC_UPLOADS_ENABLED=false
AUTH_COOKIE_NAME=erp_session
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true
CSRF_COOKIE_NAME=erp_csrf
CSRF_HEADER_NAME=x-csrf-token
TRUST_PROXY_HEADERS=true
